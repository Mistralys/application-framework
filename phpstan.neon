#
# ┌─────────────────────────────────────────────────────────────────┐
# │  DO NOT invoke vendor/bin/phpstan directly.                     │
# │  Use the Composer scripts instead:                              │
# │                                                                 │
# │    composer analyze        — run analysis                       │
# │    composer analyze-save   — run and save to phpstan-result.txt │
# │    composer analyze-clear  — clear the result cache             │
# │                                                                 │
# │  The Composer scripts set the required --memory-limit=900M      │
# │  flag. Direct invocation will OOM on large modules.             │
# │  (PHPStan 2.x removed the memoryLimit neon config key.)         │
# └─────────────────────────────────────────────────────────────────┘
#
parameters:
    level: 5
    bootstrapFiles:
        - ./tests/phpstan/constants.php
        - ./tests/phpstan/cli-utilities-stubs.php
        - ./tests/bootstrap.php
    paths:
        - ./src
        - ./tests/AppFrameworkTestClasses
        - ./tests/AppFrameworkTests
        - ./tests/application/assets
        - ./tests/application/ajax
        - ./tests/application/api
        - ./tests/application/themes/default/templates
        - ./tests/application/xml
    dynamicConstantNames:
        - APP_ROOT
        - APP_TESTS_RUNNING
        - APP_FRAMEWORK_TESTS
        - TESTSUITE_DB_PORT
    ignoreErrors:
        -
            message: '#this might not be defined.#'
            path: ./src/themes/default*
        -
            identifier: nullCoalesce.expr
            paths:
                - ./tests/application/assets/classes/TestDriver/Environments/EnvironmentsConfig.php
